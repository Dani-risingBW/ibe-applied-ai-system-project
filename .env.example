# Copy this file to .env and fill in real values. Never commit .env to git.

# Anthropic API key — required for Phase 7 AI Search and conflict suggestions
# Obtain from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-...

# LibCal OAuth2 credentials (one pair per library using the libcal adapter)
# Obtain from: LibCal Admin > API > OAuth2 > Add Client
FOUNDERS_CLIENT_ID=your_client_id_here
FOUNDERS_CLIENT_SECRET=your_client_secret_here

LAW_CLIENT_ID=your_client_id_here
LAW_CLIENT_SECRET=your_client_secret_here

SCIENCE_CLIENT_ID=your_client_id_here
SCIENCE_CLIENT_SECRET=your_client_secret_here
